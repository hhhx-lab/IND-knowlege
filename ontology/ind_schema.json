    ],
    "axioms": [
      {
        "id": "Axiom1",
        "description": "If Impurity exceeds limit (e.g., high molecular weight >5%), then must have associated ToxicologyStudy for safety evaluation.",
        "formal": "∀x (Impurity(x) ∧ exceedsLimit(x, B) → ∃y (ToxicologyStudy(y) ∧ assesses(y, x)))",
        "rationale": "Derived from module 3 quality controls linking to module 4 tox studies for impurity risks."
      },
      {
        "id": "Axiom2",
        "description": "A ClinicalTrial requires prior NonclinicalStudy support for starting DoseLevel (e.g., MABEL-based).",
        "formal": "∀x (ClinicalTrial(x) → ∃y (NonclinicalStudy(y) ∧ supports(y, x)))",
        "rationale": "Cross-link from 1.3.4 protocol to module 4, ensuring nonclinical bridging."
      },
      {
        "id": "Axiom3",
        "description": "RiskManagementPlan must include monitoring for AdverseEvent in cohorts with high DoseLevel.",
        "formal": "∀x (Cohort(x) ∧ highDoseLevel(x) → ∃y (RiskManagement(y) ∧ managesRiskOf(y, AdverseEvent)))",
        "rationale": "From 1.8 risk management tied to 1.3.4 cohort dosing."
      },
      {
        "id": "Axiom4",
        "description": "Formulation stability under StorageCondition implies compatibility with PackagingSystem.",
        "formal": "∀x (Formulation(x) ∧ stableUnder(x, StorageCondition) → ∃y (PackagingSystem(y) ∧ compliesWith(x, y)))",
        "rationale": "Module 3 P.7-P.8 linkage for pharmaceutical integrity."
      },
      {
        "id": "Axiom5",
        "description": "If BiologicalActivity shows immunogenicity risk, then Protocol must include InclusionCriteria excluding high-risk patients.",
        "formal": "∀x (BiologicalActivity(x) ∧ inducesImmunogenicity(x) → ∃y (Protocol(y) ∧ contains(y, ExclusionCriteria)))",
        "rationale": "Cross from module 4 pharmacology to 1.3.4 protocol safety."
      },
      {
        "id": "Axiom6",
        "description": "Endpoint achievement in PhaseI implies DoseLevel selection for PhaseII.",
        "formal": "∀x (PhaseI(x) ∧ achievesEndpoint(x) → ∃y (DoseLevel(y) ∧ belongsTo(y, PhaseII)))",
        "rationale": "Logical progression in clinical development from summaries."
      },
      {
        "id": "Axiom7",
        "description": "AnalyticalMethod validation is required for QualityControl in ManufacturingProcess.",
        "formal": "∀x (ManufacturingProcess(x) → ∃y (AnalyticalMethod(y) ∧ validates(y, QualityControl)))",
        "rationale": "Module 3 S.4-P.5 standards."
      }
    ],
    "totalClasses": 42
  }
